# ─── Database ─────────────────────────────────────────────────────────────────
# Local:  postgresql://postgres:password@localhost:5432/codeethnics?schema=public
# AWS RDS (ap-south-1): add ?sslmode=require for RDS
DATABASE_URL="postgresql://postgres:password@localhost:5432/codeethnics?schema=public"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
APP_URL="http://localhost:5000"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Use DIFFERENT values for each secret
JWT_SECRET="your-random-access-token-secret-min-32-chars"
JWT_REFRESH_SECRET="your-random-refresh-token-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Email (Mailtrap for dev, AWS SES for prod) ───────────────────────────────
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="CodeEthnics <no-reply@codeethnics.com>"

# ─── CORS / Frontend ──────────────────────────────────────────────────────────
# Comma-separated origins: CORS_ORIGINS=https://app.codeethnics.com,https://www.codeethnics.com
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=
